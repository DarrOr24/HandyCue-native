{
  "expo": {
    "name": "HandyCue",
    "slug": "handycue",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.darrmorgan.handycue",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/app-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/app-icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5f749b3c-ddc0-47fa-884f-7e982708e5d5"
      }
    },
    "owner": "darrmorgan",
    "plugins": [
      "expo-audio"
    ]
  }
}
