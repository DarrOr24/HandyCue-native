# Supabase configuration
# Create a project at https://supabase.com/dashboard
# Then copy your URL and anon key from: Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Dev login (optional): Create user in Supabase Dashboard → Auth → Users → Add user
# No email is sent, so it bypasses rate limits. Then add credentials here for one-tap dev login.
# EXPO_PUBLIC_DEV_EMAIL=dev@test.com
# EXPO_PUBLIC_DEV_PASSWORD=devpass123
